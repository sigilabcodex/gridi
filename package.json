{
  "name": "gridi",
  "private": true,
  "version": "0.33.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:gh": "vite build --mode gh",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.mjs",
    "test:watch": "tsx --test --watch tests/*.test.mjs",
    "test:step": "tsx --test tests/eventWindowAndDedupe.test.mjs",
    "test:e2e": "tsx --test tests/e2e/*.spec.ts",
    "test:e2e:headed": "GRIDI_E2E_HEADLESS=0 tsx --test tests/e2e/*.spec.ts"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  }
}
